# Google Sheets Integration (optional — for live sync from Google Forms)
# Format: JSON array of {department, sheetId, tabName}
# Example:
# GOOGLE_SHEETS_CONFIG=[{"department":"Emergency","sheetId":"1abc123...","tabName":"ED"},{"department":"Finance","sheetId":"1abc123...","tabName":"Finance"}]

GOOGLE_SHEETS_CONFIG=

# WhatsApp via WaSenderAPI (unofficial WhatsApp API — https://wasenderapi.com)
# Create a WhatsApp Session in the WaSender dashboard, scan the QR with the
# hospital number (+916362191675), then paste that session's API key here.
WASENDER_API_KEY=
# Optional override; defaults to https://www.wasenderapi.com/api/send-message
# WASENDER_API_URL=
